AI_PROVIDER=google
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash-lite

# Optional alternatives
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=8787
VITE_PORT=5174
APP_URL=http://127.0.0.1:5174
NUBE_ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
NUBE_SECURE_COOKIES=false
# Set to true, or use npm run preflight:prod, to make launch checks fail on missing production config.
NUBE_PREFLIGHT_STRICT=false
TESSDATA_PREFIX=
NUBE_MAX_CAPTURE_CHARS=4000
NUBE_MAX_AI_FILE_CHARS=6000
NUBE_MAX_STORED_EXTRACTED_CHARS=20000

# Optional cloud database for real multi-device sync. Leave empty for local-only mode.
NUBE_CLOUD_DATABASE_PROVIDER=postgres
NUBE_CLOUD_DATABASE_URL=
NUBE_CLOUD_DATABASE_SSL=true

# Optional Stripe billing. Leave empty until paid upgrades are ready.
STRIPE_SECRET_KEY=
STRIPE_PERSONAL_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Optional production email forwarding.
NUBE_PUBLIC_DOMAIN=
NUBE_INBOUND_EMAIL_ADDRESS=
NUBE_INBOUND_EMAIL_SECRET=

# Cloudflare R2 file storage. If these are empty, uploads stay local/fallback.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional public/custom domain for preview/download URLs, for example:
# R2_PUBLIC_URL=https://files.yourdomain.com
R2_PUBLIC_URL=

# Future Supabase auth/storage values if we choose the full Supabase stack later.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
