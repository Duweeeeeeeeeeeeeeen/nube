{
  "name": "nube",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/server.mjs",
    "dev:full": "node server/dev.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preflight": "node --check server/server.mjs && node --check server/cloudDatabase.mjs && node server/preflight.mjs",
    "preflight:prod": "node --check server/server.mjs && node --check server/cloudDatabase.mjs && node server/preflight.mjs --production",
    "start": "node server/server.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "busboy": "^1.6.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
